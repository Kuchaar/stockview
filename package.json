{
  "name": "stockview",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npx wrangler pages dev -- npx vite",
    "update-prices": "node scripts/fetch-stooq.mjs",
    "build": "vite build",
    "postbuild": "node scripts/generate-sitemap.mjs && react-snap",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "skipThirdPartyRequests": true,
    "include": [
      "/",
      "/stock/pkobp",
      "/stock/orlen",
      "/stock/kghm",
      "/stock/pzu",
      "/stock/pekao",
      "/stock/cdprojekt",
      "/stock/modivo",
      "/stock/dino",
      "/stock/lpp",
      "/stock/cyfrplsat",
      "/stock/mbank",
      "/stock/jsw",
      "/stock/pge",
      "/stock/kruk",
      "/stock/ccc",
      "/stock/pepco",
      "/stock/assecopol",
      "/stock/orangepl",
      "/stock/alior",
      "/stock/kety"
    ],
    "crawl": false,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage", "--disable-gpu"],
    "concurrency": 1,
    "saveAs": "html"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.7",
    "vite": "^5.4.0",
    "wrangler": "^3.99.0"
  }
}
